#!/bin/bash
set -euo pipefail

# Generate ~/.pg_service.conf from 1Password.
# Fetches connection topology (host, port, db, user) for each named service.
# Passwords are NOT stored — use psql-connect to inject them at runtime.
#
# Usage: gen-pg-service <service-name> [service-name ...]
# Convention: service [FOO] -> 1Password item FOO_POSTGRESQL (Employee vault)
# Ex: `gen-pg-service LOCAL DEV QA`

if [[ $# -eq 0 ]]; then
  echo "Usage: gen-pg-service <service-name> [service-name ...]" >&2
  exit 1
fi

OUTFILE="${PGSERVICEFILE:-$HOME/.pg_service.conf}"

{
  echo "# PostgreSQL service connection file — generated by gen-pg-service"
  echo "# Regenerate with: gen-pg-service $*"
  echo "# Passwords are managed via 1Password (psql-connect)"
  echo ""

  for SERVICE in "$@"; do
    OP_ITEM="${SERVICE}_POSTGRESQL"
    echo "Fetching ${OP_ITEM}..." >&2

    IFS=',' read -r HOSTNAME PORT DATABASE USERNAME <<< "$(
      op item get "$OP_ITEM" \
        --vault Employee \
        --fields label=hostname,label=port,label=database,label=username
    )"

    echo "[${SERVICE}]"
    echo "host=${HOSTNAME}"
    echo "port=${PORT}"
    echo "dbname=${DATABASE}"
    echo "user=${USERNAME}"
    echo ""
  done
} > "$OUTFILE"

echo "Written to ${OUTFILE}" >&2
