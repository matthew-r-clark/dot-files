#!/bin/bash
set -euo pipefail

VAULT="Employee"
PREFIX="Docker - "

item_title() {
  printf '%s%s' "$PREFIX" "$1"
}

case "${1:-}" in
  store)
    input=$(cat)
    server=$(printf '%s' "$input" | jq -r '.ServerURL')
    username=$(printf '%s' "$input" | jq -r '.Username')
    secret=$(printf '%s' "$input" | jq -r '.Secret')
    title=$(item_title "$server")

    if op item get "$title" --vault "$VAULT" </dev/null &>/dev/null; then
      op item edit "$title" --vault "$VAULT" \
        "username[text]=$username" \
        "password[concealed]=$secret" </dev/null >/dev/null
    else
      op item create \
        --vault "$VAULT" \
        --category=Login \
        --title="$title" \
        --url="$server" \
        "username[text]=$username" \
        "password[concealed]=$secret" </dev/null >/dev/null
    fi
    ;;

  get)
    server=$(cat)
    title=$(item_title "$server")
    creds=$(op item get "$title" --vault "$VAULT" \
      --fields label=username,label=password --reveal --format json 2>/dev/null) || {
      printf 'credentials not found\n' >&2
      exit 1
    }
    username=$(printf '%s' "$creds" | jq -r '.[] | select(.label == "username") | .value')
    secret=$(printf '%s' "$creds" | jq -r '.[] | select(.label == "password") | .value')
    jq -n --arg s "$server" --arg u "$username" --arg p "$secret" \
      '{"ServerURL":$s,"Username":$u,"Secret":$p}'
    ;;

  erase)
    server=$(cat)
    title=$(item_title "$server")
    op item delete "$title" --vault "$VAULT" --archive &>/dev/null || true
    ;;

  list)
    items=$(op item list --vault "$VAULT" --categories Login --format json 2>/dev/null)
    printf '%s' "$items" | jq --arg prefix "$PREFIX" '
      [ .[] | select(.title | startswith($prefix)) ]
      | map({
          key: .title[($prefix | length):],
          value: (.additional_information // "")
        })
      | from_entries
    '
    ;;

  version)
    printf '{"Version":"1.0.0"}\n'
    ;;

  *)
    printf 'Usage: docker-credential-1password {store|get|erase|list|version}\n' >&2
    exit 1
    ;;
esac
