# Artifactory tokens are injected via env vars (see nix/modules/env-secrets.nix).
# To rotate tokens, run `npm-login` from any shell — do NOT run `npm login` directly,
# as it will overwrite this file's ${VAR} placeholders with a real token.
email=matthew.clark@taillight.com
always-auth=true
registry=https://artifactory.internal.taillight.cloud/artifactory/api/npm/npm/
@odyssey:registry=https://artifactory.internal.taillight.cloud/artifactory/api/npm/tlo-npm/
//artifactory.internal.taillight.cloud/artifactory/api/npm/npm/:_authToken=${ARTIFACTORY_NPM_TOKEN}
//artifactory.internal.taillight.cloud/artifactory/api/npm/tlo-npm/:_authToken=${ARTIFACTORY_TLO_NPM_TOKEN}
